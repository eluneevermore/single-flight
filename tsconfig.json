{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "moduleDetection": "force",
    "module": "preserve",
    "resolveJsonModule": true,
    "allowJs": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "noImplicitThis": true,
    "types": ["vitest/globals"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"]
}
